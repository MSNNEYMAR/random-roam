{
  "functions": {
    "api/amap.js": {
      "maxDuration": 10
    },
    "api/health.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/amap/:path+",
      "destination": "/api/amap?path=$path"
    },
    {
      "source": "/api/google/:path*",
      "destination": "https://maps.googleapis.com/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
